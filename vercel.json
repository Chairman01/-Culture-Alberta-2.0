{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "redirects": [
        {
            "source": "/ads.txt",
            "destination": "https://adstxt.mediavine.com/sites/culturealberta/ads.txt",
            "statusCode": 301
        },
        {
            "source": "/(.*)",
            "has": [
                {
                    "type": "host",
                    "value": "culturealberta.com"
                }
            ],
            "destination": "https://www.culturealberta.com/$1",
            "permanent": true
        }
    ],
    "headers": [
        {
            "source": "/articles/(.*)",
            "headers": [
                {
                    "key": "X-Robots-Tag",
                    "value": "all"
                }
            ]
        }
    ],
    "crons": [
        {
            "path": "/api/newsletter/send",
            "schedule": "0 14 * * *"
        },
        {
            "path": "/api/cron/weekend-events?city=all&status=draft",
            "schedule": "0 20 * * 4"
        },
        {
            "path": "/api/cron/weekend-weather?status=draft",
            "schedule": "45 19 * * 4"
        },
        {
            "path": "/api/cron/major-projects-sync",
            "schedule": "30 13 * * *"
        },
        {
            "path": "/api/cron/sync-jobs?city=all",
            "schedule": "0 13 * * *"
        },
        {
            "path": "/api/cron/weekly-jobs?city=all&status=draft",
            "schedule": "0 14 * * 1"
        }
    ]
}
